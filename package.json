{
  "name": "alberta-hospital-wait-times",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "pipeline": "tsx src/pipelines/orchestrator.ts",
    "daily-sync": "tsx src/pipelines/dailySync.ts",
    "push:all": "tsx src/pipelines/pushClient.ts --all",
    "deploy:worker": "cd cloudflare && wrangler deploy",
    "deploy:pages": "wrangler pages deploy dist --project-name alberta-hospital-wait-times",
    "seed:kv": "cd cloudflare && wrangler kv key put --remote",
    "gen:push-secret": "openssl rand -hex 24"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/cors": "^2.8.19",
    "@vitejs/plugin-react": "^5.0.4",
    "adm-zip": "^0.5.16",
    "axios": "^1.18.1",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.4.0",
    "domhandler": "^5.0.3",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdf-parse": "^2.4.5",
    "puppeteer": "^25.3.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.9.0",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "xlsx": "^0.18.5",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
