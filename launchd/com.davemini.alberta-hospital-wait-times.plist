<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.davemini.alberta-hospital-wait-times</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/davemini/Antigravity/AlbertaHospitals/scripts/start-server.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/davemini/Antigravity/AlbertaHospitals</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/davemini/.local/bin:/Users/davemini/.local/lib/nodejs/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/Users/davemini</string>
        <key>NODE_ENV</key>
        <string>production</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>StandardOutPath</key>
    <string>/Users/davemini/Antigravity/AlbertaHospitals/logs/wait-times.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/davemini/Antigravity/AlbertaHospitals/logs/wait-times.err.log</string>
</dict>
</plist>
