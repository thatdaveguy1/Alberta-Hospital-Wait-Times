# HMAC secret for signing push requests from local server to Cloudflare Worker
PUSH_SECRET="generate with: openssl rand -hex 24"

# Cloudflare Worker URL for the push client
CLOUDFLARE_WORKER_URL="https://alberta-hospital-wait-times.longmad.workers.dev"

# Discord webhook URL for state-transition alerts.
# Leave empty to disable sending; local state is still updated and logged.
# To wire later, create a webhook in Discord and paste it here:
# ALERT_DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/..."

# Optional: override the path where the monitor keeps deduplication state.
# Default is logs/monitor-state.json (gitignored).
# MONITOR_STATE_FILE="logs/monitor-state.json"

# Optional: dedupe window for repeated alerts, in milliseconds.
# Default is 1800000 (30 minutes).
# ALERT_DEDUPE_MS=1800000
